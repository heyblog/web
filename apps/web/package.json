{
  "name": "@zhblogs/web",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "dev": "astro dev",
    "format": "prettier --config ./prettier.config.ts --write \"package.json\" \"*.ts\" \"src/**/*.{ts,js,astro,svelte,css}\" \"tests/**/*.{ts,js}\"",
    "format:check": "prettier --config ./prettier.config.ts --check \"package.json\" \"*.ts\" \"src/**/*.{ts,js,astro,svelte,css}\" \"tests/**/*.{ts,js}\"",
    "lint": "pnpm run lint:eslint && pnpm run stylelint",
    "lint:eslint": "eslint --config ./eslint.config.ts \"src/**/*.{ts,js,astro,svelte}\" \"tests/**/*.{ts,js}\" \"*.ts\"",
    "lint:eslint:fix": "eslint --config ./eslint.config.ts \"src/**/*.{ts,js,astro,svelte}\" \"tests/**/*.{ts,js}\" \"*.ts\" --fix",
    "lint:fix": "pnpm run lint:eslint:fix && pnpm run stylelint:fix",
    "start": "node dist/server/index.mjs",
    "stylelint": "stylelint --config ./stylelint.config.ts \"src/**/*.{css,astro,svelte}\"",
    "stylelint:fix": "stylelint --config ./stylelint.config.ts --fix \"src/**/*.{css,astro,svelte}\"",
    "test": "pnpm test:unit",
    "test:e2e": "playwright test",
    "test:unit": "vitest run tests/unit",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/node": "^10.0.6",
    "@astrojs/partytown": "^2.1.7",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/svelte": "^8.1.0",
    "@tabler/icons-svelte-runes": "^3.41.1",
    "@tailwindcss/vite": "^4.2.4",
    "@zhblogs/configs": "workspace:*",
    "astro": "^6.2.0",
    "svelte": "^5.55.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "tw-animate-css": "^1.4.0"
  }
}

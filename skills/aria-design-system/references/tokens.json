{
  "$description": "Aria Design System — W3C DTCG design tokens. Flat 2.0 + Minimal, celadon-teal primary, radius ≤ 6px, light/dark dual-mode. Semantic color roles are provided as two isomorphic light and dark sets.",
  "primitive": {
    "color": {
      "$description": "Raw color scales. Never reference these directly in components — go through the semantic layer.",
      "white": { "$type": "color", "$value": "#FFFFFF" },
      "black": { "$type": "color", "$value": "#000000" },
      "teal": {
        "$description": "Celadon teal — cool, porcelain-like blue-green; evokes flowing data and quiet clarity for the indie-blog aggregation product.",
        "50": { "$type": "color", "$value": "#EFF8F8" },
        "100": { "$type": "color", "$value": "#D9EEEF" },
        "200": { "$type": "color", "$value": "#B3DEE0" },
        "300": { "$type": "color", "$value": "#7FC5C9" },
        "400": { "$type": "color", "$value": "#3FA6AC" },
        "500": { "$type": "color", "$value": "#158187" },
        "600": { "$type": "color", "$value": "#0F7B80" },
        "700": { "$type": "color", "$value": "#0C666B" },
        "800": { "$type": "color", "$value": "#0B5357" },
        "900": { "$type": "color", "$value": "#0A4346" },
        "950": { "$type": "color", "$value": "#062D2F" }
      },
      "slate": {
        "50": { "$type": "color", "$value": "#F8FAFC" },
        "100": { "$type": "color", "$value": "#F1F5F9" },
        "200": { "$type": "color", "$value": "#E2E8F0" },
        "300": { "$type": "color", "$value": "#CBD5E1" },
        "400": { "$type": "color", "$value": "#94A3B8" },
        "500": { "$type": "color", "$value": "#64748B" },
        "600": { "$type": "color", "$value": "#475569" },
        "700": { "$type": "color", "$value": "#334155" },
        "800": { "$type": "color", "$value": "#1E293B" },
        "900": { "$type": "color", "$value": "#0F172A" },
        "950": { "$type": "color", "$value": "#020617" }
      },
      "zinc": {
        "$description": "Neutral (zero blue cast) grays — the dark-mode neutral scale. Light mode keeps slate.",
        "100": { "$type": "color", "$value": "#F4F4F5" },
        "400": { "$type": "color", "$value": "#A1A1AA" },
        "500": { "$type": "color", "$value": "#71717A" },
        "700": { "$type": "color", "$value": "#3F3F46" },
        "800": { "$type": "color", "$value": "#27272A" },
        "900": { "$type": "color", "$value": "#18181B" },
        "950": { "$type": "color", "$value": "#09090B" }
      },
      "emerald": {
        "50": { "$type": "color", "$value": "#ECFDF5" },
        "100": { "$type": "color", "$value": "#D1FAE5" },
        "300": { "$type": "color", "$value": "#6EE7B7" },
        "400": { "$type": "color", "$value": "#34D399" },
        "500": { "$type": "color", "$value": "#10B981" },
        "600": { "$type": "color", "$value": "#059669" },
        "700": { "$type": "color", "$value": "#047857" },
        "950": { "$type": "color", "$value": "#022C22" }
      },
      "amber": {
        "50": { "$type": "color", "$value": "#FFFBEB" },
        "100": { "$type": "color", "$value": "#FEF3C7" },
        "300": { "$type": "color", "$value": "#FCD34D" },
        "400": { "$type": "color", "$value": "#FBBF24" },
        "500": { "$type": "color", "$value": "#F59E0B" },
        "600": { "$type": "color", "$value": "#D97706" },
        "700": { "$type": "color", "$value": "#B45309" },
        "950": { "$type": "color", "$value": "#451A03" }
      },
      "rose": {
        "50": { "$type": "color", "$value": "#FFF1F2" },
        "100": { "$type": "color", "$value": "#FFE4E6" },
        "300": { "$type": "color", "$value": "#FDA4AF" },
        "400": { "$type": "color", "$value": "#FB7185" },
        "500": { "$type": "color", "$value": "#F43F5E" },
        "600": { "$type": "color", "$value": "#E11D48" },
        "700": { "$type": "color", "$value": "#BE123C" },
        "950": { "$type": "color", "$value": "#4C0519" }
      },
      "sky": {
        "50": { "$type": "color", "$value": "#F0F9FF" },
        "100": { "$type": "color", "$value": "#E0F2FE" },
        "300": { "$type": "color", "$value": "#7DD3FC" },
        "400": { "$type": "color", "$value": "#38BDF8" },
        "500": { "$type": "color", "$value": "#0EA5E9" },
        "600": { "$type": "color", "$value": "#0284C7" },
        "700": { "$type": "color", "$value": "#0369A1" },
        "950": { "$type": "color", "$value": "#082F49" }
      }
    },
    "dimension": {
      "space": {
        "$description": "4px-base spacing scale.",
        "1": { "$type": "dimension", "$value": "4px" },
        "2": { "$type": "dimension", "$value": "8px" },
        "3": { "$type": "dimension", "$value": "12px" },
        "4": { "$type": "dimension", "$value": "16px" },
        "6": { "$type": "dimension", "$value": "24px" },
        "8": { "$type": "dimension", "$value": "32px" },
        "12": { "$type": "dimension", "$value": "48px" },
        "16": { "$type": "dimension", "$value": "64px" }
      },
      "breakpoint": {
        "$description": "Mobile-first min-width breakpoints. Below xs uses the base layout; no implicit device breakpoints are allowed.",
        "xs": { "$type": "dimension", "$value": "30rem", "$description": "480px" },
        "sm": { "$type": "dimension", "$value": "48rem", "$description": "768px" },
        "md": { "$type": "dimension", "$value": "64rem", "$description": "1024px" },
        "lg": { "$type": "dimension", "$value": "80rem", "$description": "1280px" },
        "xl": { "$type": "dimension", "$value": "90rem", "$description": "1440px" },
        "2xl": { "$type": "dimension", "$value": "120rem", "$description": "1920px" }
      },
      "radius": {
        "$description": "Corner radius. Hard cap at 6px; `full` is allowed ONLY for avatars, pill badges or status dots, switches, radio controls, progress tracks, and step markers.",
        "xs": { "$type": "dimension", "$value": "2px" },
        "sm": { "$type": "dimension", "$value": "4px" },
        "md": { "$type": "dimension", "$value": "6px" },
        "full": { "$type": "dimension", "$value": "9999px" }
      }
    },
    "typography": {
      "fontFamily": {
        "sans": { "$type": "fontFamily", "$value": ["Inter", "Noto Sans SC", "system-ui", "sans-serif"] },
        "mono": { "$type": "fontFamily", "$value": ["JetBrains Mono", "ui-monospace", "monospace"] }
      },
      "fontSize": {
        "xs": { "$type": "dimension", "$value": "12px" },
        "sm": { "$type": "dimension", "$value": "14px" },
        "base": { "$type": "dimension", "$value": "16px" },
        "lg": { "$type": "dimension", "$value": "18px" },
        "xl": { "$type": "dimension", "$value": "20px" },
        "2xl": { "$type": "dimension", "$value": "24px" },
        "3xl": { "$type": "dimension", "$value": "30px" },
        "4xl": { "$type": "dimension", "$value": "36px" }
      },
      "fontWeight": {
        "regular": { "$type": "fontWeight", "$value": 400 },
        "medium": { "$type": "fontWeight", "$value": 500 },
        "semibold": { "$type": "fontWeight", "$value": 600 },
        "bold": { "$type": "fontWeight", "$value": 700 }
      },
      "lineHeight": {
        "tight": { "$type": "number", "$value": 1.2, "$description": "Headings ≥ 24px." },
        "snug": { "$type": "number", "$value": 1.4, "$description": "Sub-headings, UI labels." },
        "normal": { "$type": "number", "$value": 1.5, "$description": "Body text." }
      }
    },
    "shadow": {
      "$description": "Tailwind CSS v4 standard shadow scale. Flat 2.0 uses lower levels: 2xs for resting surfaces, xs for hover, sm for popovers, md for modal and toast.",
      "2xs": {
        "$type": "shadow",
        "$value": { "color": "#0000000D", "offsetX": "0px", "offsetY": "1px", "blur": "0px", "spread": "0px" }
      },
      "xs": {
        "$type": "shadow",
        "$value": { "color": "#0000000D", "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px" }
      },
      "sm": {
        "$type": "shadow",
        "$value": [
          { "color": "#0000001A", "offsetX": "0px", "offsetY": "1px", "blur": "3px", "spread": "0px" },
          { "color": "#0000001A", "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "-1px" }
        ],
        "$description": "Dropdown, popover, tooltip."
      },
      "md": {
        "$type": "shadow",
        "$value": [
          { "color": "#0000001A", "offsetX": "0px", "offsetY": "4px", "blur": "6px", "spread": "-1px" },
          { "color": "#0000001A", "offsetX": "0px", "offsetY": "2px", "blur": "4px", "spread": "-2px" }
        ],
        "$description": "Modal and toast only."
      }
    },
    "duration": {
      "micro": { "$type": "duration", "$value": "80ms", "$description": "Tooltip intent delay and short sequencing beat." },
      "fast": { "$type": "duration", "$value": "150ms", "$description": "Color/border/opacity hovers." },
      "base": { "$type": "duration", "$value": "250ms", "$description": "Switch, tab, accordion, dropdown and modal entrance." },
      "medium": { "$type": "duration", "$value": "350ms", "$description": "Toast and secondary panel exit." },
      "slow": { "$type": "duration", "$value": "400ms", "$description": "Toast and content panel entrance." },
      "emphasis": { "$type": "duration", "$value": "500ms", "$description": "Staggered content reveal and other emphasis moments." }
    },
    "easing": {
      "standard": { "$type": "cubicBezier", "$value": [0.4, 0, 0.2, 1], "$description": "Tailwind ease-in-out; reversible state transitions." },
      "out": { "$type": "cubicBezier", "$value": [0.22, 1, 0.36, 1], "$description": "Smooth out; elements and anchored surfaces entering or leaving the screen." },
      "linear": { "$type": "cubicBezier", "$value": [0, 0, 1, 1], "$description": "Constant motion for spinner and indeterminate progress." },
      "pulse": { "$type": "cubicBezier", "$value": [0.4, 0, 0.6, 1], "$description": "Tailwind standard animate-pulse easing." }
    }
  },
  "semantic": {
    "color": {
      "$description": "Purpose-based aliases. Two isomorphic sets: `light` maps to :root, `dark` maps to the `.dark` class.",
      "light": {
        "bg": {
          "canvas": { "$type": "color", "$value": "{primitive.color.slate.50}", "$description": "Page background." },
          "surface": { "$type": "color", "$value": "{primitive.color.white}", "$description": "Cards, panels, inputs, modals." },
          "subtle": { "$type": "color", "$value": "{primitive.color.slate.100}", "$description": "Hover fills, table stripes, secondary buttons." },
          "inverse": { "$type": "color", "$value": "{primitive.color.slate.900}" }
        },
        "fg": {
          "default": { "$type": "color", "$value": "{primitive.color.slate.900}" },
          "muted": { "$type": "color", "$value": "{primitive.color.slate.500}", "$description": "Secondary text, descriptions." },
          "subtle": { "$type": "color", "$value": "{primitive.color.slate.400}", "$description": "Placeholders, disabled text, tertiary icons." },
          "inverse": { "$type": "color", "$value": "{primitive.color.slate.50}" },
          "onPrimary": { "$type": "color", "$value": "{primitive.color.white}" }
        },
        "border": {
          "default": { "$type": "color", "$value": "{primitive.color.slate.200}", "$description": "Structural 1px dividers — the primary depth cue in Flat 2.0." },
          "strong": { "$type": "color", "$value": "{primitive.color.slate.500}", "$description": "Input and control boundaries; 4.76:1 against white surfaces." },
          "focus": { "$type": "color", "$value": "{primitive.color.teal.600}" }
        },
        "action": {
          "primary": {
            "default": { "$type": "color", "$value": "{primitive.color.teal.600}", "$description": "Filled primary action background; not the default small-text link color." },
            "hover": { "$type": "color", "$value": "{primitive.color.teal.700}" },
            "active": { "$type": "color", "$value": "{primitive.color.teal.800}" },
            "disabled": { "$type": "color", "$value": "{primitive.color.teal.300}" },
            "tintBg": { "$type": "color", "$value": "{primitive.color.teal.50}", "$description": "Color-first secondary emphasis: tinted fill." },
            "tintFg": { "$type": "color", "$value": "{primitive.color.teal.700}", "$description": "Secondary action and text-link foreground." }
          }
        },
        "status": {
          "$description": "fg/bg are the default text-status pair. solid is a saturated graphic or control fill and does not imply white foreground.",
          "success": {
            "fg": { "$type": "color", "$value": "{primitive.color.emerald.700}" },
            "bg": { "$type": "color", "$value": "{primitive.color.emerald.50}" },
            "border": { "$type": "color", "$value": "{primitive.color.emerald.500}" },
            "solid": { "$type": "color", "$value": "{primitive.color.emerald.600}" }
          },
          "warning": {
            "fg": { "$type": "color", "$value": "{primitive.color.amber.700}" },
            "bg": { "$type": "color", "$value": "{primitive.color.amber.50}" },
            "border": { "$type": "color", "$value": "{primitive.color.amber.500}" },
            "solid": { "$type": "color", "$value": "{primitive.color.amber.500}" }
          },
          "danger": {
            "fg": { "$type": "color", "$value": "{primitive.color.rose.700}" },
            "bg": { "$type": "color", "$value": "{primitive.color.rose.50}" },
            "border": { "$type": "color", "$value": "{primitive.color.rose.500}" },
            "solid": { "$type": "color", "$value": "{primitive.color.rose.600}" }
          },
          "info": {
            "fg": { "$type": "color", "$value": "{primitive.color.sky.700}" },
            "bg": { "$type": "color", "$value": "{primitive.color.sky.50}" },
            "border": { "$type": "color", "$value": "{primitive.color.sky.500}" },
            "solid": { "$type": "color", "$value": "{primitive.color.sky.600}" }
          }
        }
      },
      "dark": {
        "bg": {
          "canvas": { "$type": "color", "$value": "{primitive.color.zinc.950}" },
          "surface": { "$type": "color", "$value": "{primitive.color.zinc.900}" },
          "subtle": { "$type": "color", "$value": "{primitive.color.zinc.800}" },
          "inverse": { "$type": "color", "$value": "{primitive.color.zinc.100}" }
        },
        "fg": {
          "default": { "$type": "color", "$value": "{primitive.color.zinc.100}" },
          "muted": { "$type": "color", "$value": "{primitive.color.zinc.400}" },
          "subtle": { "$type": "color", "$value": "{primitive.color.zinc.500}" },
          "inverse": { "$type": "color", "$value": "{primitive.color.zinc.900}" },
          "onPrimary": { "$type": "color", "$value": "{primitive.color.white}" }
        },
        "border": {
          "default": { "$type": "color", "$value": "{primitive.color.zinc.800}" },
          "strong": { "$type": "color", "$value": "{primitive.color.zinc.500}", "$description": "Input and control boundaries; 3.67:1 against zinc-900 surfaces." },
          "focus": { "$type": "color", "$value": "{primitive.color.teal.400}", "$description": "Clearly visible on zinc-900 and zinc-950 surfaces." }
        },
        "action": {
          "primary": {
            "default": { "$type": "color", "$value": "{primitive.color.teal.500}", "$description": "Filled primary action background; not the default small-text link color." },
            "hover": { "$type": "color", "$value": "{primitive.color.teal.600}", "$description": "Keeps white labels above WCAG AA contrast." },
            "active": { "$type": "color", "$value": "{primitive.color.teal.700}" },
            "disabled": { "$type": "color", "$value": "{primitive.color.teal.900}" },
            "tintBg": { "$type": "color", "$value": "#0A434666", "$description": "teal-900 @ 40% — tinted fill on dark surfaces." },
            "tintFg": { "$type": "color", "$value": "{primitive.color.teal.300}", "$description": "Secondary action and text-link foreground." }
          }
        },
        "status": {
          "$description": "fg/bg are the default text-status pair. solid is a saturated graphic or control fill and does not imply white foreground.",
          "success": {
            "fg": { "$type": "color", "$value": "{primitive.color.emerald.400}" },
            "bg": { "$type": "color", "$value": "#022C224D" },
            "border": { "$type": "color", "$value": "{primitive.color.emerald.500}" },
            "solid": { "$type": "color", "$value": "{primitive.color.emerald.500}" }
          },
          "warning": {
            "fg": { "$type": "color", "$value": "{primitive.color.amber.400}" },
            "bg": { "$type": "color", "$value": "#451A034D" },
            "border": { "$type": "color", "$value": "{primitive.color.amber.500}" },
            "solid": { "$type": "color", "$value": "{primitive.color.amber.500}" }
          },
          "danger": {
            "fg": { "$type": "color", "$value": "{primitive.color.rose.400}" },
            "bg": { "$type": "color", "$value": "#4C05194D" },
            "border": { "$type": "color", "$value": "{primitive.color.rose.500}" },
            "solid": { "$type": "color", "$value": "{primitive.color.rose.600}", "$description": "Keeps white labels above WCAG AA contrast." }
          },
          "info": {
            "fg": { "$type": "color", "$value": "{primitive.color.sky.400}" },
            "bg": { "$type": "color", "$value": "#082F494D" },
            "border": { "$type": "color", "$value": "{primitive.color.sky.500}" },
            "solid": { "$type": "color", "$value": "{primitive.color.sky.500}" }
          }
        }
      }
    },
    "focusRing": {
      "width": { "$type": "dimension", "$value": "2px" },
      "offset": { "$type": "dimension", "$value": "2px" },
      "$description": "2px ring + 2px offset in border.focus color, :focus-visible only."
    },
    "overlay": {
      "scrim": {
        "light": { "$type": "color", "$value": "#0F172A99", "$description": "Modal backdrop, light mode — slate-900 @ 60%." },
        "dark": { "$type": "color", "$value": "#09090BB3", "$description": "Modal backdrop, dark mode — zinc-950 @ 70%." }
      }
    }
  },
  "component": {
    "$description": "Mode-neutral component geometry, typography, elevation, and motion. Component descriptions name the semantic color roles consumed in either mode.",
    "button": {
      "height": {
        "sm": { "$type": "dimension", "$value": "32px" },
        "md": { "$type": "dimension", "$value": "36px" },
        "lg": { "$type": "dimension", "$value": "40px" }
      },
      "paddingX": {
        "sm": { "$type": "dimension", "$value": "{primitive.dimension.space.3}" },
        "md": { "$type": "dimension", "$value": "{primitive.dimension.space.4}" },
        "lg": { "$type": "dimension", "$value": "20px" }
      },
      "radius": { "$type": "dimension", "$value": "{primitive.dimension.radius.md}" },
      "fontWeight": { "$type": "fontWeight", "$value": "{primitive.typography.fontWeight.medium}" },
      "activeScale": { "$type": "number", "$value": 0.96, "$description": "Pressed-state scale, duration.fast; keyboard activation stays spatially still." },
      "transition": { "$type": "duration", "$value": "{primitive.duration.fast}", "$description": "Explicit color, border-color, and scale transitions; shadows are not interpolated." },
      "loadingRotation": { "$type": "duration", "$value": "1000ms", "$description": "Tailwind standard animate-spin cycle; linear and disabled under reduced motion." }
    },
    "input": {
      "$description": "Color roles: border.strong, border.focus, and status.danger.solid. Error messages use status.danger.fg.",
      "height": { "$type": "dimension", "$value": "40px", "$description": "Compact control height from breakpoint.sm." },
      "touchHeight": { "$type": "dimension", "$value": "44px", "$description": "Base mobile/touch control height below breakpoint.sm." },
      "paddingX": { "$type": "dimension", "$value": "{primitive.dimension.space.3}" },
      "radius": { "$type": "dimension", "$value": "{primitive.dimension.radius.md}" },
      "focusTransition": { "$type": "duration", "$value": "{primitive.duration.fast}", "$description": "Border-color only; the focus-visible outline appears immediately." },
      "shakeDuration": { "$type": "duration", "$value": "280ms", "$description": "6px → -6px → 4px → 0; easing.out. Disabled under reduced motion." }
    },
    "card": {
      "$description": "Color role: border.default. Hover lift is reserved for cards with an actual action and fine-pointer devices.",
      "padding": { "$type": "dimension", "$value": "{primitive.dimension.space.6}" },
      "radius": { "$type": "dimension", "$value": "{primitive.dimension.radius.md}" },
      "shadow": { "$type": "shadow", "$value": "{primitive.shadow.2xs}" },
      "hoverLift": { "$type": "dimension", "$value": "-1px", "$description": "Interactive cards: translateY on hover + shadow.xs." },
      "hoverTransition": { "$type": "duration", "$value": "{primitive.duration.base}", "$description": "Transform and border-color only; the target shadow token switches without interpolation." }
    },
    "badge": {
      "height": { "$type": "dimension", "$value": "20px" },
      "paddingX": { "$type": "dimension", "$value": "{primitive.dimension.space.2}" },
      "radius": { "$type": "dimension", "$value": "{primitive.dimension.radius.sm}" },
      "pillRadius": { "$type": "dimension", "$value": "{primitive.dimension.radius.full}", "$description": "Pill variant — radius.full exception list member." },
      "fontSize": { "$type": "dimension", "$value": "{primitive.typography.fontSize.xs}" },
      "dismissHitTarget": { "$type": "dimension", "$value": "44px", "$description": "Touch target; compact desktop target is 40px from breakpoint.sm." },
      "dismissTransition": { "$type": "duration", "$value": "{primitive.duration.base}" }
    },
    "switch": {
      "width": { "$type": "dimension", "$value": "36px" },
      "height": { "$type": "dimension", "$value": "20px" },
      "hitTarget": { "$type": "dimension", "$value": "44px", "$description": "Touch label-row target; compact desktop target is 40px. Visual track remains 36×20px." },
      "thumbSize": { "$type": "dimension", "$value": "16px" },
      "radius": { "$type": "dimension", "$value": "{primitive.dimension.radius.full}", "$description": "radius.full exception list member." },
      "thumbTransition": { "$type": "duration", "$value": "{primitive.duration.base}" }
    },
    "checkbox": {
      "size": { "$type": "dimension", "$value": "16px" },
      "radius": { "$type": "dimension", "$value": "{primitive.dimension.radius.sm}" },
      "hitTarget": { "$type": "dimension", "$value": "44px", "$description": "Touch label-row target; compact desktop target is 40px. Visual control remains 16px." },
      "activeScale": { "$type": "number", "$value": 0.96 },
      "stateTransition": { "$type": "duration", "$value": "{primitive.duration.fast}", "$description": "Fill, border, checkmark size, opacity and press scale." },
      "indeterminateMarkWidth": { "$type": "dimension", "$value": "10px", "$description": "White horizontal mark; the native mixed state remains exposed to accessibility APIs." }
    },
    "radio": {
      "size": { "$type": "dimension", "$value": "16px" },
      "radius": { "$type": "dimension", "$value": "{primitive.dimension.radius.full}", "$description": "radius.full exception list member." },
      "selectedDotSize": { "$type": "dimension", "$value": "6px" },
      "hitTarget": { "$type": "dimension", "$value": "44px", "$description": "Touch label-row target; compact desktop target is 40px. Visual control remains 16px." },
      "activeScale": { "$type": "number", "$value": 0.96 },
      "stateTransition": { "$type": "duration", "$value": "{primitive.duration.fast}", "$description": "Border, selected-dot scale, opacity and press scale." }
    },
    "slider": {
      "$description": "Uses the current semantic primary accent and preserves native range behavior.",
      "hitTarget": { "$type": "dimension", "$value": "44px", "$description": "Touch target; compact desktop target is 40px." }
    },
    "avatar": {
      "size": {
        "sm": { "$type": "dimension", "$value": "28px" },
        "md": { "$type": "dimension", "$value": "36px" },
        "lg": { "$type": "dimension", "$value": "48px" }

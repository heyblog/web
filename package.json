{
  "name": "app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "env:dev": "node ./scripts/run-with-env.mjs --env .env.dev --",
    "env:prod": "node ./scripts/run-with-env.mjs --env .env.prod --",
    "env:test": "node ./scripts/run-with-env.mjs --env .env.test --",
    "build": "pnpm run build:app",
    "build:api": "pnpm env:prod -- \"pnpm run build:packages && pnpm -F @zhblogs/api run build\"",
    "build:app": "pnpm env:prod -- \"pnpm run build:packages && pnpm -F @zhblogs/api run build && pnpm -F @zhblogs/worker run build && pnpm -F @zhblogs/web run build\"",
    "build:cf": "pnpm env:prod -- \"CLOUDFLARE_INCLUDE_PROCESS_ENV=true pnpm -F @zhblogs/cloudflare run build\"",
    "build:packages": "pnpm --filter @zhblogs/db --filter @zhblogs/utils --if-present run build",
    "build:worker": "pnpm env:prod -- \"pnpm -F @zhblogs/worker run build\"",
    "build:web": "pnpm env:prod -- \"pnpm run build:packages && pnpm -F @zhblogs/web run build\"",
    "deploy:cf": "pnpm env:prod -- \"CLOUDFLARE_INCLUDE_PROCESS_ENV=true pnpm -F @zhblogs/cloudflare run deploy\"",
    "commit:lint": "commitlint --from HEAD~1 --to HEAD",
    "db:generate": "pnpm env:dev -- \"pnpm -F @zhblogs/db drizzle generate\"",
    "db:migrate": "pnpm env:dev -- \"pnpm -F @zhblogs/db drizzle migrate\"",
    "db:studio": "pnpm env:dev -- \"pnpm -F @zhblogs/db drizzle studio\"",
    "dev": "pnpm run dev:app",
    "dev:api": "pnpm env:dev -- \"pnpm -F @zhblogs/api run dev\"",
    "dev:app": "pnpm env:dev -- \"pnpm --parallel -F @zhblogs/api -F @zhblogs/cloudflare -F @zhblogs/worker -F @zhblogs/web run dev\"",
    "dev:worker": "pnpm env:dev -- \"pnpm -F @zhblogs/worker run dev\"",
    "dev:web": "pnpm env:dev -- \"pnpm -F @zhblogs/web run dev\"",
    "dev:cf": "pnpm env:dev -- \"CLOUDFLARE_INCLUDE_PROCESS_ENV=true pnpm -F @zhblogs/cloudflare run dev\"",
    "format": "pnpm -r --if-present run format",
    "format:check": "pnpm -r --if-present run format:check",
    "hooks:install": "node ./scripts/install-git-hooks.mjs",
    "hooks:pre-commit": "node ./scripts/pre-commit.mjs",
    "lint": "pnpm -r --if-present run lint",
    "lint:fix": "pnpm -r --if-present run lint:fix",
    "prepare": "node ./scripts/install-git-hooks.mjs && pnpm run build:packages",
    "start": "pnpm run start:app",
    "start:api": "pnpm env:prod -- \"pnpm -F @zhblogs/api run start\"",
    "start:app": "pnpm env:prod -- \"pnpm --parallel -F @zhblogs/api -F @zhblogs/cloudflare -F @zhblogs/worker -F @zhblogs/web run start\"",
    "start:worker": "pnpm env:prod -- \"pnpm -F @zhblogs/worker run start\"",
    "start:web": "pnpm env:prod -- \"pnpm -F @zhblogs/web run start\"",
    "start:cf": "pnpm env:prod -- \"CLOUDFLARE_INCLUDE_PROCESS_ENV=true pnpm -F @zhblogs/cloudflare run start\"",
    "tasks:seed": "pnpm env:dev -- \"node --import tsx ./apps/api/scripts/seed-task-schedules.ts\"",
    "tasks:seed:sync": "pnpm env:dev -- \"node --import tsx ./apps/api/scripts/seed-task-schedules.ts --sync\"",
    "test": "pnpm run test:app",
    "test:all": "pnpm run test",
    "test:api": "pnpm env:test -- \"pnpm -F @zhblogs/api run test\"",
    "test:app": "pnpm env:test -- \"pnpm -F @zhblogs/api -F @zhblogs/cloudflare -F @zhblogs/worker -F @zhblogs/web run test\"",
    "test:cf": "pnpm env:test -- \"pnpm -F @zhblogs/cloudflare run test\"",
    "test:worker": "pnpm env:test -- \"pnpm -F @zhblogs/worker run test\"",
    "test:web": "pnpm env:test -- \"pnpm -F @zhblogs/web run test\"",
    "typecheck": "pnpm -r --if-present run typecheck",
    "util:psl:update-rules": "pnpm -F @zhblogs/utils run psl:update-rules"
  },
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=24.15.0",
    "pnpm": ">=10.33.2"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "astro-eslint-parser": "^1.4.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-svelte": "^3.17.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.5.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "stylelint": "^17.9.1",
    "stylelint-config-standard": "^40.0.0",
    "tsdown": "^0.21.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "zod": "^4.4.1"
  }
}
